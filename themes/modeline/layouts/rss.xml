{{- /* Custom RSS feed. Overrides Hugo's embedded template so that the home
feed only carries posts (not standalone pages like /about). Items carry the
post summary plus the banner image (front matter `banner`, served from
static/) as both <enclosure> and <media:content> so feed readers show it as
the preview. Applies to every RSS output: home, sections, and tag terms. */ -}}
{{- $pages := .RegularPages -}}
{{- if .IsHome -}}
  {{- $pages = where site.RegularPages "Section" "posts" -}}
{{- end -}}
{{- $limit := site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
  {{- $pages = $pages | first $limit -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ if .IsHome }}{{ site.Title }}{{ else }}{{ .Title }} · {{ site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ .Description | default site.Params.description | default site.Title }}</description>
    <generator>Hugo</generator>
    <language>{{ site.Language.LanguageCode }}</language>
    {{- with site.Params.copyright }}
    <copyright>{{ . }}</copyright>
    {{- end }}
    {{- with index $pages 0 }}
    <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- end }}
    {{- with .OutputFormats.Get "rss" }}
    <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml" />
    {{- end }}
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      {{- range .GetTerms "tags" }}
      <category>{{ .LinkTitle }}</category>
      {{- end }}
      <description>{{ .Description | default (.Summary | plainify) | transform.XMLEscape | safeHTML }}</description>
      {{- with .Params.banner }}
      {{- $mime := index (dict ".png" "image/png" ".jpg" "image/jpeg" ".jpeg" "image/jpeg" ".webp" "image/webp" ".gif" "image/gif") (path.Ext . | lower) | default "image/png" }}
      {{- $length := 0 }}
      {{- $file := printf "static%s" . }}
      {{- if fileExists $file }}{{ with os.Stat $file }}{{ $length = .Size }}{{ end }}{{ end }}
      <enclosure url="{{ . | absURL }}" length="{{ $length }}" type="{{ $mime }}" />
      <media:content url="{{ . | absURL }}" medium="image" type="{{ $mime }}" />
      {{- end }}
    </item>
    {{- end }}
  </channel>
</rss>
